# مسار مطلق (اختياري — إذا بدك تحدد مكان الملف بنفسك):
# DATABASE_URL=sqlite:////root/home/alipride/bot_ich/data/telegram_bot.db

# MySQL — لا تستخدمه إلا إذا بدك قاعدة خارجية:
# DATABASE_URL=mysql+pymysql://user:password@localhost/ichancy_bot

# ─── حدود المعاملات (ل.س) ───────────────────────────────────
