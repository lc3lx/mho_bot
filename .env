ICHANCY_API_URL=https://www.ichancy.com

# حساب الوكيل (Agent) — نفس بيانات تسجيل الدخول على لوحة الوكيل
ICHANCY_USERNAME=agent_username
ICHANCY_PASSWORD=agent_password

# parentId المطلوب عند تسجيل لاعب جديد (اختياري)
