# ============================================================
# ichancy Telegram Bot - copy to .env and fill values
# cp .env.example .env && nano .env
# ============================================================

# --- Webhook (port 6001) ---
BOT_MODE=webhook
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=6001
WEBHOOK_PATH=telegram-webhook
WEBHOOK_URL=https://yourdomain.com/telegram-webhook
WEBHOOK_SECRET=ichancy_bot_secret_6001

# --- Telegram ---
BOT_TOKEN=PUT_BOT_TOKEN_HERE
BOT_USERNAME=Napoleonrobert_bot
BOT_DISPLAY_NAME=Napoleon_bot
ADMIN_IDS=123456789

FACEBOOK_URL=https://facebook.com/yourpage
TELEGRAM_CHANNEL_URL=https://t.me/yourchannel
TELEGRAM_SUPPORT_URL=https://t.me/yoursupport

# --- Local SQLite DB ---
DATABASE_URL=sqlite:///data/telegram_bot.db

# --- Limits ---
MIN_DEPOSIT=10
MAX_DEPOSIT=100000
MIN_WITHDRAWAL=20
MAX_WITHDRAWAL=50000
MAX_SAVED_SYRIATEL=10
MAX_SAVED_SHAMCASH=1
MIN_GIFT=5
REFERRAL_PERCENTAGE=10

# --- API SYRIA ---
APISYRIA_API_KEY=PUT_APISYRIA_KEY_HERE
APISYRIA_BASE_URL=https://apisyria.com/api/v1
APISYRIA_SYRIATEL_GSM=0933xxxxxx
APISYRIA_SYRIATEL_CODES=09148503,93774818
APISYRIA_SYRIATEL_PIN=
APISYRIA_SHAMCASH_ACCOUNT=251awxxxxxxxxxxxxxxxxx
APISYRIA_CURRENCY=SYP
APISYRIA_TX_PERIOD=7
APISYRIA_DEPOSIT_TIMEOUT=15
SYRIATEL_DEPOSIT_TIMEOUT=5
SYRIATEL_TX_DIGITS=12
SYRIATEL_MIN_DEPOSIT=1000
SHAMCASH_MIN_SYP=200
SHAMCASH_MIN_USD=2
SHAMCASH_USD_RATE=13125

# --- USDT ---
USDT_WALLET_ADDRESS=Txxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRONGRID_URL=https://api.trongrid.io
TRONGRID_API_KEY=
USDT_SYP_RATE=15000
USDT_DEPOSIT_TIMEOUT=30
USDT_POLL_INTERVAL=30
USDT_MIN_CONFIRMATIONS=1

# --- ichancy ---
ICHANCY_API_URL=https://www.ichancy.com
ICHANCY_USERNAME=agent_username
ICHANCY_PASSWORD=agent_password
ICHANCY_PARENT_ID=
ICHANCY_CURRENCY=EUR
ICHANCY_CURRENCY_CODE=EUR
ICHANCY_MONEY_STATUS=5
ICHANCY_WITHDRAW_COOLDOWN=30
ICHANCY_MIN_TOPUP=20000

# --- Other ---
MIN_JACKPOT=1000
JACKPOT_CONTRIBUTION_RATE=0.01
JACKPOT_DRAW_TIME=23:59
SUPPORT_PHONE=+963912345678
SUPPORT_EMAIL=support@example.com
SUPPORT_HOURS=24/7
SUPPORT_TELEGRAM=@your_support
MAX_DAILY_WITHDRAWALS=3
MAX_DAILY_DEPOSITS=10
WITHDRAWAL_COOLDOWN=3600
REQUIRE_ADMIN_APPROVAL=true
AUTO_BAN_THRESHOLD=10
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/bot.log
DEBUG=False
